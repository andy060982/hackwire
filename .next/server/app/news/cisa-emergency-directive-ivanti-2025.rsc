12:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"CISA Issues Emergency Directive ED-25-02: Ivanti Connect Secure Exploitation Ongoing\",\"description\":\"The Cybersecurity and Infrastructure Security Agency has issued Emergency Directive ED-25-02, ordering all federal civilian agencies to immediately disconnect or apply mitigations to Ivanti Connect Secure and Policy Secure appliances amid confirmed exploitation by multiple threat actors.\",\"datePublished\":\"2025-01-11T18:00:00Z\",\"dateModified\":\"2025-01-11T18:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"HackWire Editorial\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"HackWire\",\"url\":\"https://hackwire.news\"},\"url\":\"https://hackwire.news/news/cisa-emergency-directive-ivanti-2025\",\"keywords\":\"CISA, Ivanti, emergency directive, federal, CVE-2025-0282\"}"}}],["$","article",null,{"className":"max-w-7xl mx-auto px-4 py-8","children":[["$","nav",null,{"className":"flex items-center gap-2 text-xs font-mono text-gray-600 mb-6","children":[["$","$L2",null,{"href":"/","className":"hover:text-[#00FF88] transition-colors","children":"HOME"}],["$","span",null,{"children":"/"}],["$","$L2",null,{"href":"/category/policy","className":"hover:text-[#00FF88] transition-colors uppercase","children":"policy"}],["$","span",null,{"children":"/"}],["$","span",null,{"className":"text-gray-500 truncate max-w-xs","children":"CISA-EMERGENCY-DIRECTIVE-IVANTI-2025"}]]}],["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-3 gap-10","children":[["$","div",null,{"className":"lg:col-span-2","children":[["$","div",null,{"className":"flex flex-wrap items-center gap-3 mb-5","children":[["$","span",null,{"className":"inline-flex items-center gap-1 rounded font-mono font-semibold tracking-wider uppercase border text-xs px-2.5 py-1 text-blue-400 bg-blue-500/10 border-blue-500/30","children":