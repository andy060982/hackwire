16:{"metadata":[["$","title","0",{"children":"MediSecure Health Network Exposes 14 Million Patient Records in Catastrophic Data Breach | HackWire"}],["$","meta","1",{"name":"description","content":"A ransomware-linked breach at MediSecure Health Network has exposed the personal health information of over 14 million patients across 38 US states. The attack, attributed to the BlackSuit ransomware group, compromised EHR databases containing Social Security numbers, diagnoses, and insurance data."}],["$","meta","2",{"name":"author","content":"HackWire Editorial"}],["$","meta","3",{"name":"keywords","content":"cybersecurity news,data breaches,vulnerabilities,malware,ransomware,infosec"}],["$","meta","4",{"name":"robots","content":"index, follow"}],["$","meta","5",{"property":"og:title","content":"MediSecure Health Network Exposes 14 Million Patient Records in Catastrophic Data Breach"}],["$","meta","6",{"property":"og:description","content":"A ransomware-linked breach at MediSecure Health Network has exposed the personal health information of over 14 million patients across 38 US states. The attack, attributed to the BlackSuit ransomware group, compromised EHR databases containing Social Security numbers, diagnoses, and insurance data."}],["$","meta","7",{"property":"og:url","content":"https://hackwire.news/news/medisecure-healthcare-breach-2025"}],["$","meta","8",{"property":"og:type","content":"article"}],["$","meta","9",{"property":"article:published_time","content":"2025-01-14T09:30:00Z"}],["$","meta","10",{"property":"article:tag","content":"healthcare"}],["$","meta","11",{"property":"article:tag","content":"HIPAA"}],["$","meta","12",{"property":"article:tag","content":"ransomware"}],["$","meta","13",{"property":"article:tag","content":"BlackSuit"}],["$","meta","14",{"property":"article:tag","content":"data breach"}],["$","meta","15",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","16",{"name":"twitter:title","content":"MediSecure Health Network Exposes 14 Million Patient Records in Catastrophic Data Breach"}],["$","meta","17",{"name":"twitter:description","content":"A ransomware-linked breach at MediSecure Health Network has exposed the personal health information of over 14 million patients across 38 US states. The attack, attributed to the BlackSuit ransomware group, compromised EHR databases containing Social Security numbers, diagnoses, and insurance data."}]],"error":null,"digest":"$undefined"}
