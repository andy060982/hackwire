12:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"MediSecure Health Network Exposes 14 Million Patient Records in Catastrophic Data Breach\",\"description\":\"A ransomware-linked breach at MediSecure Health Network has exposed the personal health information of over 14 million patients across 38 US states. The attack, attributed to the BlackSuit ransomware group, compromised EHR databases containing Social Security numbers, diagnoses, and insurance data.\",\"datePublished\":\"2025-01-14T09:30:00Z\",\"dateModified\":\"2025-01-14T09:30:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"HackWire Editorial\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"HackWire\",\"url\":\"https://hackwire.news\"},\"url\":\"https://hackwire.news/news/medisecure-healthcare-breach-2025\",\"keywords\":\"healthcare, HIPAA, ransomware, BlackSuit, data breach\"}"}}],["$","article",null,{"className":"max-w-7xl mx-auto px-4 py-8","children":[["$","nav",null,{"className":"flex items-center gap-2 text-xs font-mono text-gray-600 mb-6","children":[["$","$L2",null,{"href":"/","className":"hover:text-[#00FF88] transition-colors","children":"HOME"}],["$","span",null,{"children":"/"}],["$","$L2",null,{"href":"/category/breaches","className":"hover:text-[#00FF88] transition-colors uppercase","children":"breaches"}],["$","span",null,{"children":"/"}],["$","span",null,{"className":"text-gray-500 truncate max-w-xs","children":"MEDISECURE-HEALTHCARE-BREACH-2025"}]]}],["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-3 gap-10","children":[["$","div",null,{"className":"lg:col-span-2","children":[["$","div",null,{"className":"flex flex-wrap items-center gap-3 mb-5","children":[["$","span",null,{"className":"inline-flex items-center gap-1 rounded font-mono font-semibold tracking-wider uppercase border text-xs px-2.5 py-1 text-red-400 bg-red-500/10 border-red-500/30","chil