16:{"metadata":[["$","title","0",{"children":"Global Cybersecurity Workforce Gap Reaches 4.8 Million: New ISC2 Study Highlights Diversity Crisis | HackWire"}],["$","meta","1",{"name":"description","content":"ISC2's 2025 Cybersecurity Workforce Study finds the global shortage of cybersecurity professionals has grown to 4.8 million, up 15% from 2024. The report identifies AI skill gaps and a severe decline in entry-level hiring as primary drivers, with workforce diversity declining for the first time in five years."}],["$","meta","2",{"name":"author","content":"HackWire Editorial"}],["$","meta","3",{"name":"keywords","content":"cybersecurity news,data breaches,vulnerabilities,malware,ransomware,infosec"}],["$","meta","4",{"name":"robots","content":"index, follow"}],["$","meta","5",{"property":"og:title","content":"Global Cybersecurity Workforce Gap Reaches 4.8 Million: New ISC2 Study Highlights Diversity Crisis"}],["$","meta","6",{"property":"og:description","content":"ISC2's 2025 Cybersecurity Workforce Study finds the global shortage of cybersecurity professionals has grown to 4.8 million, up 15% from 2024. The report identifies AI skill gaps and a severe decline in entry-level hiring as primary drivers, with workforce diversity declining for the first time in five years."}],["$","meta","7",{"property":"og:url","content":"https://hackwire.news/news/cybersecurity-workforce-shortage-report-2025"}],["$","meta","8",{"property":"og:type","content":"article"}],["$","meta","9",{"property":"article:published_time","content":"2024-12-31T10:00:00Z"}],["$","meta","10",{"property":"article:tag","content":"workforce"}],["$","meta","11",{"property":"article:tag","content":"talent shortage"}],["$","meta","12",{"property":"article:tag","content":"ISC2"}],["$","meta","13",{"property":"article:tag","content":"diversity"}],["$","meta","14",{"property":"article:tag","content":"AI skills"}],["$","meta","15",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","16",{"name":"twitter:title","content":"Global Cybersecurity Workforce Gap Reaches 4.8 Million: New ISC2 Study Highlights Diversity Crisis"}],["$","meta","17",{"name":"twitter:description","content":"ISC2's 2025 Cybersecurity Workforce Study finds the global shortage of cybersecurity professionals has grown to 4.8 million, up 15% from 2024. The report identifies AI skill gaps and a severe decline in entry-level hiring as primary drivers, with workforce diversity declining for the first time in five years."}]],"error":null,"digest":"$undefined"}
